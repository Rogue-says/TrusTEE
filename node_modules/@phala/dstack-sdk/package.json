{
  "name": "@phala/dstack-sdk",
  "version": "0.5.8",
  "description": "dstack SDK",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.mts",
        "require": "./dist/index.d.ts"
      },
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./viem": {
      "types": {
        "import": "./dist/viem.d.mts",
        "require": "./dist/viem.d.ts"
      },
      "import": "./dist/viem.mjs",
      "require": "./dist/viem.js"
    },
    "./solana": {
      "types": {
        "import": "./dist/solana.d.mts",
        "require": "./dist/solana.d.ts"
      },
      "import": "./dist/solana.mjs",
      "require": "./dist/solana.js"
    },
    "./encrypt-env-vars": {
      "types": {
        "import": "./dist/encrypt-env-vars.d.mts",
        "require": "./dist/encrypt-env-vars.d.ts"
      },
      "import": "./dist/encrypt-env-vars.mjs",
      "require": "./dist/encrypt-env-vars.js"
    },
    "./get-compose-hash": {
      "types": {
        "import": "./dist/get-compose-hash.d.mts",
        "require": "./dist/get-compose-hash.d.ts"
      },
      "import": "./dist/get-compose-hash.mjs",
      "require": "./dist/get-compose-hash.js"
    },
    "./verify-env-encrypt-public-key": {
      "types": {
        "import": "./dist/verify-env-encrypt-public-key.d.mts",
        "require": "./dist/verify-env-encrypt-public-key.d.ts"
      },
      "import": "./dist/verify-env-encrypt-public-key.mjs",
      "require": "./dist/verify-env-encrypt-public-key.js"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "test": "vitest",
    "test:ci": "vitest --run",
    "release": "npm run clean && npm run build && npm publish --access public"
  },
  "keywords": [
    "sdk",
    "dstack",
    "Phala"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Dstack-TEE/dstack",
    "directory": "sdk/js"
  },
  "author": "Leechael Yim",
  "license": "Apache-2.0",
  "devDependencies": {
    "@noble/curves": "^1.8.1",
    "@noble/hashes": "^1.6.1",
    "@solana/web3.js": "^1.98.4",
    "@types/node": "latest",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "viem": "^2.43.3",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "@noble/curves": "^1.8.1",
    "@noble/hashes": "^1.6.1",
    "@solana/web3.js": "^1.98.4",
    "viem": "^2.43.3"
  },
  "peerDependenciesMeta": {
    "@noble/curves": {
      "optional": true
    },
    "@solana/web3.js": {
      "optional": true
    },
    "viem": {
      "optional": true
    }
  }
}
